\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Representative field-management interfaces in GrapeMaster: (a) user login, (b) field list and weather overview, and (c) map-based field-boundary editing.}}{13}{figure.6}\protected@file@percent }
