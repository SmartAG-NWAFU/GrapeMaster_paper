\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Weather, operation-suitability, and crop-season status interfaces: (a) weather detail and multi-day forecast, (b) hourly weather and spraying-suitability display, and (c) field-level disease-risk and growth-stage forecasts.}}{14}{figure.7}\protected@file@percent }
\newlabel{fig:weather_risk_interfaces}{{7}{14}{Weather, operation-suitability, and crop-season status interfaces: (a) weather detail and multi-day forecast, (b) hourly weather and spraying-suitability display, and (c) field-level disease-risk and growth-stage forecasts}{figure.7}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {5.3}Disease-Risk Warning and Treatment-Window Review}{15}{subsection.5.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces Seasonal disease-risk output timeline generated from disease-model test outputs. Panels show (a) the Mingyang 2024 crop season, (b) the GXG-233 crop season without fungicide history, and (c) the GXG-233 crop season with fungicide history. Each panel contains daily risk states for downy mildew, powdery mildew, and field-level risk. Colors indicate the model risk code: not seasonal, unfavorable, favorable, optimal, or protected. The dashed vertical line in panel (c) marks the fungicide application date used by the model to produce protected risk states.}}{15}{figure.8}\protected@file@percent }
\newlabel{fig:seasonal_disease_risk_timeline}{{8}{15}{Seasonal disease-risk output timeline generated from disease-model test outputs. Panels show (a) the Mingyang 2024 crop season, (b) the GXG-233 crop season without fungicide history, and (c) the GXG-233 crop season with fungicide history. Each panel contains daily risk states for downy mildew, powdery mildew, and field-level risk. Colors indicate the model risk code: not seasonal, unfavorable, favorable, optimal, or protected. The dashed vertical line in panel (c) marks the fungicide application date used by the model to produce protected risk states}{figure.8}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces Warning and notification interfaces in GrapeMaster: (a) disease alert dialog, (b) irrigation notice with task-creation action, and (c) notification list.}}{16}{figure.9}\protected@file@percent }
\newlabel{fig:alert_notification_interfaces}{{9}{16}{Warning and notification interfaces in GrapeMaster: (a) disease alert dialog, (b) irrigation notice with task-creation action, and (c) notification list}{figure.9}{}}
