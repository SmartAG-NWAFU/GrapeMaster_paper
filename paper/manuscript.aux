\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Disease-model simulation workflow in GrapeMaster. Hourly weather, crop growth stage, cultivar information, fungicide history, and target disease settings are converted into weather response, host correction, protection correction, and risk-timeline outputs, which support disease-risk display, field-risk interpretation, protection-time tracking, recommendations, and treatment-window generation.}}{9}{figure.3}\protected@file@percent }
\newlabel{fig:disease_model_workflow}{{3}{9}{Disease-model simulation workflow in GrapeMaster. Hourly weather, crop growth stage, cultivar information, fungicide history, and target disease settings are converted into weather response, host correction, protection correction, and risk-timeline outputs, which support disease-risk display, field-risk interpretation, protection-time tracking, recommendations, and treatment-window generation}{figure.3}{}}
